{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "cloudflare-ai",
  "title": "Cloudflare Workers AI",
  "description": "Interact with Cloudflare Workers AI directly in your Raycast window",
  "icon": "extension-icon.png",
  "author": "dharmin_nagar",
  "contributors": [
    "code-parth"
  ],
  "platforms": [
    "macOS",
    "Windows"
  ],
  "categories": [
    "Productivity",
    "Developer Tools"
  ],
  "license": "MIT",
  "commands": [
    {
      "name": "query-cloudflare-ai",
      "title": "Query Cloudflare AI",
      "description": "Ask questions to Cloudflare AI models",
      "mode": "view"
    },
    {
      "name": "conversations",
      "title": "View Conversations",
      "description": "View and manage your Cloudflare AI conversation history",
      "mode": "view"
    }
  ],
  "preferences": [
    {
      "name": "accountId",
      "type": "textfield",
      "required": true,
      "title": "Account ID",
      "description": "Your Cloudflare Account ID",
      "placeholder": "Enter your Cloudflare Account ID"
    },
    {
      "name": "apiToken",
      "type": "password",
      "required": true,
      "title": "API Token",
      "description": "Your Cloudflare API Token with Workers AI permissions",
      "placeholder": "Enter your API Token"
    },
    {
      "name": "defaultModel",
      "type": "dropdown",
      "required": false,
      "title": "Default Model",
      "description": "Default AI model to use",
      "default": "@cf/meta/llama-3.1-8b-instruct",
      "data": [
        {
          "title": "Kimi K2.5",
          "value": "@cf/moonshotai/kimi-k2.5"
        },
        {
          "title": "GLM 4.7 Flash",
          "value": "@cf/zai-org/glm-4.7-flash"
        },
        {
          "title": "GPT OSS 120B",
          "value": "@cf/openai/gpt-oss-120b"
        },
        {
          "title": "GPT OSS 20B",
          "value": "@cf/openai/gpt-oss-20b"
        },
        {
          "title": "Llama 4 Scout 17B 16E Instruct",
          "value": "@cf/meta/llama-4-scout-17b-16e-instruct"
        },
        {
          "title": "Nemotron 3 120B A12B",
          "value": "@cf/nvidia/nemotron-3-120b-a12b"
        },
